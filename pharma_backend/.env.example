# Copier ce fichier vers .env et remplir les valeurs
DEBUG=True
SECRET_KEY=your-secret-key-here

# Base de données (localhost en dev, nom du service Docker en prod)
DB_NAME=pharma_db
DB_USER=postgres
DB_PASSWORD=your-password-here
DB_HOST=localhost
DB_PORT=5432

# Docker Compose — surcharger ces valeurs dans docker-compose.yml
# DB_HOST=db  # nom du service PostgreSQL dans le réseau Docker