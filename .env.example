# Variables pour docker-compose.yml
# Copier vers .env à la racine du projet et remplir les valeurs

# ── Backend Django ──────────────────────────────────────────────────────────
DEBUG=False
SECRET_KEY=change-this-to-a-long-random-secret-key

# ── Base de données PostgreSQL ──────────────────────────────────────────────
DB_NAME=pharma_db
DB_USER=postgres
DB_PASSWORD=change-this-password
# DB_HOST est surchargé automatiquement par docker-compose (valeur: db)

# ── Frontend ────────────────────────────────────────────────────────────────
# URL de l'API vue depuis le navigateur (pas depuis le réseau Docker)
VITE_API_BASE_URL=http://localhost:8000/api/v1
